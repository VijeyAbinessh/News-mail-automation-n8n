  "nodes": [
    {
      "parameters": {
        "jsCode": "const rss = $json.rss || {};\nconst channel = rss.channel?.[0] || rss.channel || {};\nconst items = channel.item || [];\n\nconst topNews = items.slice(0,5);\n\nconst formatted = topNews.map(n => {\n  const title = Array.isArray(n.title) ? n.title[0] : n.title;\n  const link = Array.isArray(n.link) ? n.link[0] : n.link;\n  return `📰 ${title}\\n${link}`;\n}).join(\"\\n\\n\");\n\nreturn [\n  {\n    json: {\n      emailContent: formatted\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2096,
        0
      ],
      "id": "9d3b391a-2a8e-493c-bfc1-6a408431fc85",
      "name": "Code in JavaScript"
    },
