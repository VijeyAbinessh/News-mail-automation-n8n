      "parameters": {
        "sendTo": "vijeyabinesshclg11@gmail.com",
        "subject": "Daily morning news",
        "message": "=Here are today's top news headlines:\n\n{{$json[\"emailContent\"]}}",
        "options": {}
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
