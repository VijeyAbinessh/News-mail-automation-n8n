            {
              "name": "Authorization",
              "value": "Bearer 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"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n \"model\": \"llama-3.3-70b-versatile\",\n \"messages\": [\n   {\n     \"role\": \"system\",\n     \"content\": \"Generate 5 Google News search queries based on the user topic. Return one query per line.\"\n   },\n   {\n     \"role\": \"user\",\n     \"content\": \"News topic: {{ $json.chatInput }}\"\n   }\n ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1264,
        0
      ],
      "id": "6fedbe69-cb1e-46a5-b805-c57c0e9fe314",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const queries = $json.choices[0].message.content\n  .split(\"\\n\")\n  .map(q => q.replace(/\"/g,\"\").trim())\n  .filter(q => q);\n\nreturn queries.map(q => ({\n  json: {\n    query: q,\n    rss: `https://news.google.com/rss/search?q=${encodeURIComponent(q)}`\n  }\n}));"
      },
